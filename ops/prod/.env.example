APP_DOMAIN=chat.example.com
LIVEKIT_DOMAIN=voice.example.com
ACME_EMAIL=you@example.com

POSTGRES_USER=atlas
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=atlas

JWT_SECRET=replace-with-64-char-secret
JWT_EXPIRES_MIN=4320

LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret-min-32-chars
LIVEKIT_TOKEN_TTL_MIN=240

# livekit turn
TURN_ENABLED=true
TURN_DOMAIN=voice.example.com
TURN_UDP_PORT=3478
TURN_TLS_PORT=0

# livekit rtc
RTC_TCP_PORT=7881
RTC_PORT_RANGE_START=50000
RTC_PORT_RANGE_END=52000
RTC_USE_EXTERNAL_IP=true
